# NetBox Configuration
NETBOX_URL=http://localhost:8000
NETBOX_TOKEN=your-netbox-api-token-here

# LLM Backend Selection
# Choose backend: "ollama" or "llamacpp"
LLM_BACKEND=ollama

# Ollama Configuration (when LLM_BACKEND=ollama)
# Default below points at a cloud model (Ollama Cloud Pro subscription required —
# run `ollama signin` once, then the local daemon proxies :cloud models to ollama.com).
# For a fully local model swap OLLAMA_MODEL to e.g. qwen2.5:32b-instruct-q4_K_M.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-v4-pro:cloud
OLLAMA_TEMPERATURE=0.0

# Llama.cpp Configuration (when LLM_BACKEND=llamacpp — privacy-mode fallback)
LLAMACPP_BASE_URL=http://localhost:58123/v1
LLAMACPP_MODEL=Qwen_Qwen3-14B-Q5_K_M.gguf
LLAMACPP_API_KEY=not-needed

# DeepAgents Configuration
DEEPAGENTS_LOG_LEVEL=INFO
DEEPAGENTS_USE_SKILLS=true
DEEPAGENTS_CACHE_ENABLED=true

# Development Settings
DEBUG=false
TEST_MODE=false
LOG_LEVEL=INFO

# MCP Server Configuration (optional)
MCP_SERVER_PATH=/home/ola/dev/rnd/mcp/testmcp/netbox-mcp-server

# LangSmith Tracing (optional, for debugging and observability)
# Get your API key from https://smith.langchain.com/
# LANGCHAIN_API_KEY=lsv2_pt_your_api_key_here
# LANGCHAIN_PROJECT=netbox-deepagents-ollama
# LANGCHAIN_TRACING_V2=true